# ── Wizarding Portfolio — environment variables ──────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets. All keys below are SERVER-SIDE only
# (no NEXT_PUBLIC_ prefix) so they are never shipped to the browser.

# Google Gemini — answers AND embeddings for the Sorting Hat (RAG).
# One free key from Google AI Studio: https://aistudio.google.com/apikey
# Used by both `npm run ingest` (embeddings) and /api/ask (answers + embeddings).
# Stay on the FREE tier — do NOT enable billing.
GEMINI_API_KEY=
# Optional model overrides (defaults shown):
# GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
# GEMINI_EMBED_MODEL=gemini-embedding-001

# Upstash Redis — answer cache + per-visitor rate limiting for /api/ask.
# Free tier: https://console.upstash.com  (Redis, NOT Vector — retrieval uses a
# committed local index, so no vector DB is needed.) Optional in local dev: if
# unset, rate-limiting is skipped and caching is a no-op — the Hat still works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — "owl post" contact form email delivery. Free key: https://resend.com/api-keys
# Until RESEND_API_KEY is set, /api/contact validates + logs the message and succeeds.
RESEND_API_KEY=
# Where messages are delivered.
CONTACT_TO_EMAIL=you@example.com
# The sender. Resend's sandbox `onboarding@resend.dev` needs NO domain setup, but can
# only deliver to the email that owns the Resend account. To send from a branded
# address to anyone, verify a domain in Resend and put it here.
CONTACT_FROM_EMAIL=Owl Post <onboarding@resend.dev>

# Cloudflare Turnstile — free invisible CAPTCHA on the contact form.
# Create a widget at https://dash.cloudflare.com → Turnstile. The SITE key is
# PUBLIC (sent to the browser, hence NEXT_PUBLIC_); the SECRET is server-side only.
# Both absent → the bot check is skipped and the form still works.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis (above) also rate-limits the contact form: ~4 submissions/IP/hour.
# Without it, rate-limiting is skipped (the honeypot + Turnstile still apply).
