# ── Wizarding Portfolio — environment variables ──────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets. All keys below are SERVER-SIDE only
# (no NEXT_PUBLIC_ prefix) so they are never shipped to the browser.

# Google Gemini — answers AND embeddings for the Sorting Hat (RAG).  [Phase 3]
# IMPORTANT: set a hard spend cap in Google AI Studio / Cloud billing before
# exposing /api/ask publicly.
GEMINI_API_KEY=

# Upstash Vector — serverless vector DB for retrieval.  [Phase 3]
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Upstash Redis — answer cache + per-visitor rate limiting.  [Phase 3]
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — "owl post" contact form email (+ honeypot for spam).  [Phase 1]
# Until this is set, /api/contact logs the message server-side and succeeds.
RESEND_API_KEY=
# The verified "from" address Resend will send as, and where mail is delivered.
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=
